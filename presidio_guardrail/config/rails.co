import core
import llm
import guardrails
import nemoguardrails.library.sensitive_data_detection

flow main
  activate llm continuation

flow input rails $input_text
  mask sensitive data on input

@override
flow mask sensitive data on input
  """Mask PII with detailed tracing."""
  global $user_message
  $user_message = await MaskSensitiveDataWithTracingAction(source="input", text=$user_message)
